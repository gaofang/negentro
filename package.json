{
  "name": "negentro",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "CLI for lowering repository entropy by distilling reusable engineering knowledge.",
  "files": [
    "src",
    "README.md",
    "package.json"
  ],
  "bin": {
    "entro": "./src/cli.js"
  },
  "scripts": {
    "entro": "node ./src/cli.js",
    "help": "node ./src/cli.js help",
    "test": "node --test ./test/*.test.js",
    "install:codex": "node ./src/cli.js install-codex --mode both"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.72.0",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "keywords": [
    "codex",
    "knowledge",
    "agents",
    "skills",
    "entropy"
  ],
  "license": "ISC"
}
